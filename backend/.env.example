# Environment Variables — ZK Resume Protocol
# Copy this to .env and fill in your values. Never commit .env!

# ── RPC Endpoints ──────────────────────────────────────────────────
# Get from Alchemy: https://dashboard.alchemy.com/
SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ── Wallet ─────────────────────────────────────────────────────────
# Deployer private key (use a dedicated testnet wallet — NOT your main wallet)
PRIVATE_KEY=0x...

# ── Etherscan (for contract verification) ──────────────────────────
# Get from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ── EAS (Ethereum Attestation Service) ─────────────────────────────
# Register your schema at https://sepolia.easscan.org/schema/create
# Schema: bytes32 studentId, uint256 cgpa, string degree
SCHEMA_UID=0x...

# ── Gas Reporting (optional) ───────────────────────────────────────
# Get from https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=
REPORT_GAS=true
